# MVP defaults to mock mode. No keys required.
CONTENT_FACTORY_MODE=mock
LIT_API_URL=http://localhost:8787/api/verdict
LIT_API_TIMEOUT_SECONDS=20
LIT_API_KEY=
LIT_APP_URL=http://127.0.0.1:5173
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_RECORDING_ENABLED=false
PLAYWRIGHT_VIEWPORT_WIDTH=1080
PLAYWRIGHT_VIEWPORT_HEIGHT=1920
TTS_ENABLED=false
TTS_PROVIDER=auto
TTS_VOICE=
TTS_TIMEOUT_SECONDS=30
TTS_STRICT=false
MUSIC_ENABLED=false
MUSIC_SOURCE=generated
MUSIC_VOLUME=0.12
MUSIC_STRICT=false
MUSIC_PATH=
PUBLISH_DRY_RUN_ENABLED=false
# Phase 5B YouTube live boundary. Keep both switches false until OAuth, quota,
# policy, metadata approval, and the optional Google client are configured.
LIVE_PUBLISHING_ENABLED=false
YOUTUBE_PUBLISHING_ENABLED=false
YOUTUBE_OAUTH_ACCESS_TOKEN=
YOUTUBE_OAUTH_SCOPES=
YOUTUBE_OAUTH_TOKEN_EXPIRES_AT=
YOUTUBE_UPLOAD_QUOTA_REMAINING=0
YOUTUBE_POLICY_ACKNOWLEDGED=false
AUTOPILOT_EMERGENCY_STOP=false
OUTPUT_DIR=output
